{
  "name": "my-game",
  "version": "0.1.0",
  "private": true,
  "description": "OpenCode PixiJS Game Studio — browser game built with PixiJS v8 + TypeScript",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "cd tools/ts-compiler-mcp && npm install"
  },
  "dependencies": {
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
